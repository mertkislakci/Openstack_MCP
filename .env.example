# ── OpenStack credentials ──────────────────────────────────────────────────────
OS_AUTH_URL=https://keystone.example.com:5000/v3
OS_USERNAME=admin
OS_PASSWORD=secret
OS_PROJECT_NAME=admin
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=RegionOne

# ── MCP Server ─────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8080
# Transport: sse (HTTP) or stdio
MCP_TRANSPORT=streamable-http
MCP_AUTH_TOKEN=           # Bearer token — boş bırakılırsa auth devre dışı

# ── MCP Proxy ─────────────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8000
# Comma-separated list of upstream MCP server URLs
PROXY_UPSTREAM_URLS=http://localhost:8080

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL=300           # seconds
CACHE_MAX_SIZE=1000

# ── Feedback ──────────────────────────────────────────────────────────────────
FEEDBACK_ENABLED=true
FEEDBACK_BUFFER_SIZE=200

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
